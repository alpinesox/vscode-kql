{
  "name": "vscode-kql",
  "displayName": "KQL",
  "description": "Offline language support for Kusto Query Language files.",
  "version": "0.0.1",
  "publisher": "alpinesox",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alpinesox/vscode-kql.git"
  },
  "files": [
    "out/**/*.js",
    "syntaxes/**",
    "language-configuration.json",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:kql"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kql",
        "aliases": [
          "KQL",
          "Kusto Query Language",
          "kql"
        ],
        "extensions": [
          ".kql",
          ".csl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kql",
        "scopeName": "source.kql",
        "path": "./syntaxes/kql.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[kql]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 4
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "security:sast": ".venv\\Scripts\\semgrep.exe scan --config auto --error",
    "security:secrets": ".tools\\bin\\trufflehog.exe git file://. --fail --no-update --results=verified",
    "security": "npm run security:secrets && npm run security:sast",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/vscode": "^1.92.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
