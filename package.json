{
  "name": "vscode-kql",
  "displayName": "KQL",
  "description": "Offline language support for Kusto Query Language files.",
  "version": "0.0.1",
  "publisher": "alpinesox",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alpinesox/vscode-kql.git"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:kql"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kql",
        "aliases": [
          "KQL",
          "Kusto Query Language",
          "kql"
        ],
        "extensions": [
          ".kql",
          ".csl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kql",
        "scopeName": "source.kql",
        "path": "./syntaxes/kql.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[kql]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 4
      }
    }
  },
  "scripts": {
    "check:main": "node -e \"const fs=require('fs'); const pkg=require('./package.json'); if (!fs.existsSync(pkg.main)) { console.error(pkg.main + ' does not exist'); process.exit(1); }\"",
    "compile": "tsc -p ./",
    "list:vsix": "vsce ls --tree",
    "package:vsix": "vsce package --out vscode-kql.vsix",
    "security:sast": "node scripts/security-sast.js",
    "security:secrets": "node scripts/security-secrets.js",
    "security": "npm run security:secrets && npm run security:sast",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.6.5",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
