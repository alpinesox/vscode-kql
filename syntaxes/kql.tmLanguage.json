{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kusto Query Language",
  "scopeName": "source.kql",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.kql", "match": "//.*$" },
        { "name": "comment.block.kql", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.single.kql", "begin": "'", "end": "'", "patterns": [{ "name": "constant.character.escape.kql", "match": "''|\\\\." }] },
        { "name": "string.quoted.double.kql", "begin": "\"", "end": "\"", "patterns": [{ "name": "constant.character.escape.kql", "match": "\\\\." }] }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.kql", "match": "\\b\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.kql", "match": "(?i)\\b(?:as|asc|between|by|contains|count|declare|desc|distinct|evaluate|extend|externaldata|facet|find|fork|getschema|has|in|invoke|join|kind|let|limit|lookup|make-series|materialize|mv-apply|mv-expand|not|on|or|order|parse|print|project|project-away|project-keep|project-rename|range|reduce|render|sample|search|serialize|sort|summarize|take|top|union|where)\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.kql", "match": "==|!=|<=|>=|=~|!~|!in~|in~|!in|[+*/%<>=|.,;:(){}\\[\\]-]" }
      ]
    },
    "functions": {
      "patterns": [
        { "name": "support.function.kql", "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()" }
      ]
    }
  }
}
